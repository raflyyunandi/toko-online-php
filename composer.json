{
  "name": "toko-online-app/toko-online-app",
  "description": "Native PHP JSON API untuk toko-online-app",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "test/"
    }
  },
  "scripts": {
    "migrate": "php database/migrate.php",
    "seed": "php database/seed.php",
    "test": "phpunit -c phpunit.xml"
  }
}
